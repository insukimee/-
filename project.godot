; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="Ragdoll Party"
config/description="2D physics-based party brawler (Gang Beasts style), 2-10 players"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

SoundFX="*res://scripts/SoundFX.gd"
FX="*res://scripts/FX.gd"

[physics]

2d/default_gravity=980

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[input]

p1_move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":65,"pressed":false,"echo":false)
]
}
p1_move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":68,"pressed":false,"echo":false)
]
}
p1_jump={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32,"pressed":false,"echo":false)
]
}
p1_grab={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194325,"location":1,"pressed":false,"echo":false)
]
}
p1_push={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"button_index":1,"pressed":false,"canceled":false,"double_click":false)
]
}
p2_move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194319,"pressed":false,"echo":false)
]
}
p2_move_right={
